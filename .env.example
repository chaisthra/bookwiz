# ── Backend (copy to backend/.env) ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
PERPLEXITY_API_KEY=pplx-...
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # Service Role key — Supabase Dashboard → Settings → API

# ── Frontend (copy to frontend/.env.local) ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # Anon key — Supabase Dashboard → Settings → API
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000   # Used by EventSource (SSE) directly from browser
